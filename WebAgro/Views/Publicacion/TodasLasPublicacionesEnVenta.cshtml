@model IEnumerable<CasosDeUsos.DTOs.PublicacionVentaDTO.ListadoPublicacionesEnVentaDTO>

@{
    ViewData["Title"] = "Publicaciones en Venta";
}

<h2>Publicaciones en Venta</h2>

@if (!Model.Any())
{
    <p>No hay publicaciones disponibles.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>#</th>
                <th>Título</th>
                <th>Marca</th>
                <th>Modelo</th>
                <th>Año</th>
                <th>Ciudad</th>
                <th>País</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pub in Model)
            {
                <tr>
                    <td>@pub.Id</td>
                    <td>@pub.Titulo</td>
                    <td>@pub.Marca</td>
                    <td>@pub.Modelo</td>
                    <td>@pub.Anio</td>
                    <td>@pub.Ciudad</td>
                    <td>@pub.Pais</td>
                </tr>
            }
        </tbody>
    </table>
}
