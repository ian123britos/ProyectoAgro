@model IEnumerable<CasosDeUsos.DTOs.PublicacionVentaDTO.ListadoPublicacionesEnVentaDTO>

@{
    ViewData["Title"] = "Maquinarias en Venta";
}
<style>

    body {
        background-color: #e8f5e9; /* Verde suave */
    }

</style>
<div class="container mt-5">

    <!-- TITULO -->
    <div class="text-center mb-5">
        <h1 class="fw-bold">🚜 Maquinarias en Venta</h1>
        <p class="text-muted fs-5">
            Encuentra la maquinaria agrícola que necesitas
        </p>
        <hr style="width:120px;margin:auto;">
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            No hay publicaciones disponibles.
        </div>
    }
    else
    {
        <div class="row g-4">

            @foreach (var pub in Model)
            {
                <div class="col-lg-4 col-md-6">

                    <div class="card h-100 shadow-sm border-0">

                        <!-- IMAGEN -->
                        <div style="overflow:hidden;">
                            <img src="@Url.Content(pub.Foto)"
                                 class="card-img-top"
                                 style="height:220px; object-fit:cover; transition:0.3s;"
                                 onerror="this.src='/images/default-maquinaria.jpg'"
                                 alt="Imagen maquinaria">
                        </div>

                        <!-- CUERPO -->
                        <div class="card-body">

                            <h5 class="card-title fw-bold">
                                @pub.Titulo
                            </h5>

                            <h4 class="text-success fw-bold mb-2">
                                USD @pub.Precio.ToString("N0")
                            </h4>

                            <p class="text-muted mb-1">
                                <strong>@pub.Marca</strong> - @pub.Modelo
                            </p>

                            <p class="mb-2">
                                Año: <strong>@pub.Anio</strong>
                            </p>

                            <p class="text-secondary mb-3">
                                📍 @pub.Ciudad, @pub.Pais
                            </p>
                         

                        </div>

                        <!-- FOOTER -->
                        <div class="card-footer bg-white border-0">

                            <a asp-controller="Publicacion"
                               asp-action="DetallePublicacionEnVenta"
                               asp-route-id="@pub.Id"
                               class="btn btn-success w-100 fw-semibold">
                                Ver Detalle
                            </a>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>

<style>

    .card:hover {
        transform: translateY(-5px);
        transition: 0.25s;
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    .card-img-top:hover {
        transform: scale(1.05);
    }

</style>