@{
}

@using Dominio
@model List<Publicacion>

@{
    ViewData["Title"] = "Publicaciones de Venta";
}

<div class="container mt-5">
    <h2 class="mb-4">📦 Publicaciones de Venta</h2>

    <table class="table table-bordered table-striped">
        <thead class="table-success">
            <tr>
                <th>Título</th>
                <th>Tipo Maquinaria</th>
                <th>Marca</th>
                <th>Modelo</th>
                <th>Año</th>
                <th>Ubicación</th>
                <th>Precio</th>
                <th>Fecha</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pub in Model)
            {
                if (pub is Venta venta)
                {
                    <tr>
                        <td>@venta.Titulo</td>
                        <td>@venta.UnaMaquina?.TipoVechiculo()</td>
                        <td>@venta.UnaMaquina?.Caracteristica?.Marca</td>
                        <td>@venta.UnaMaquina?.Caracteristica?.Modelo</td>
                        <td>@venta.UnaMaquina?.Caracteristica?.Anio</td>
                        <td>@($"{venta.UnaMaquina?.Direccion?.Barrio}, {venta.UnaMaquina?.Direccion?.Ciudad}, {venta.UnaMaquina?.Direccion?.Pais}")</td>
                        <td>$@venta.PrecioVenta</td>
                        <td>@venta.FechaPublicacionVenta.ToShortDateString()</td>
                    </tr>
                }
            }
        </tbody>

    </table>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">No hay publicaciones de venta cargadas.</div>
    }
</div>
