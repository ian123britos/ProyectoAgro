
@using Dominio
@model List<Publicacion>
<div class="container mt-5">
    <h2 class="mb-4">📦 Publicaciones de Venta</h2>

     <!-- FILTRO DE MARCA -->

     <div class="card mb-4">

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }
        <div class="card-body">
            <form asp-action="FiltradoPorMarcaDeMaquinaria" method="post" class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label for="marca" class="form-label">Filtrar por marca</label>
                    <select name="marca" id="marca" class="form-select">
                        <option value="">Buscar Maquinaria por Marca</option>
                        @{
                            var marcasUnicas = Model
                            .Where(p => p.UnaMaquina?.Caracteristica?.Marca != null)
                            .Select(p => p.UnaMaquina.Caracteristica.Marca)
                            .Distinct();

                            foreach (var marca in marcasUnicas)
                            {
                                <option value="@marca">@marca</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-auto">
                    <button class="btn btn-primary mt-3" type="submit">🔍 Buscar</button>
                </div>
            </form>
        </div>
    </div>  

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">No hay publicaciones de venta cargadas.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var pub in Model)
            {
                if (pub is Venta venta)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm">
                            @* linea para mostrar fotos: *@
                            <img src="@venta.Foto" onerror="this.onerror=null; this.src='/images/sin-imagen.png';" class="card-img-top" alt="@venta.Titulo" style="height: 200px; object-fit: cover;">
                            @* <img src="@venta.Foto" alt="Imagen de maquinaria" class="card-img-top" style="height: 200px; object-fit: cover;"> *@

                            <div class="card-body">
                                <h5 class="card-title">@venta.Titulo</h5>
                                @* <p class="card-text text-muted">@venta.UnaMaquina?.TipoVechiculo()</p> *@
                                <p class="card-text">
                                    <strong>Marca:</strong> @venta.UnaMaquina.Caracteristica.Marca <br />
                                    <strong>Modelo:</strong> @venta.UnaMaquina.Caracteristica.Modelo <br />
                                    <strong>Año:</strong> @venta.UnaMaquina.Caracteristica.Anio
                                </p>
                                <p class="card-text">
                                    <strong>Ubicación:</strong> @venta.UnaMaquina.Direccion.Ciudad, @venta.UnaMaquina.Direccion.Pais
                                </p>
                            </div>
                            <div class="card-footer d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-success">USD @venta.PrecioVenta</span>
                                <a href="@Url.Action("ObtenerMaquinariaPorId", "Publicacion", new { id = pub.UnaMaquina.IdMaquinaria })"
                                   class="btn"
                                   style="background-color: rgba(0, 128, 0, 0.1); color: green; border: 1px solid green; border-radius: 5px; padding: 5px 10px; transition: background-color 0.3s ease;"
                                   onmouseover="this.style.backgroundColor='rgba(0, 128, 0, 0.2)'"
                                   onmouseout="this.style.backgroundColor='rgba(0, 128, 0, 0.1)'">
                                    Ver Detalle
                                </a>
                                @* <small class="text-muted">@venta.FechaPublicacionVenta.ToShortDateString()</small> *@
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
</div>

