@{
}
@using Dominio
@model Tractor

@{
    ViewData["Title"] = "Paso 3 - Información del Tractor";
}

<div class="container mt-5 p-4 rounded shadow" style="background-color: white;">
    <h3>🚜 Paso 3 - Información del Tractor</h3>

    <form asp-action="FormularioTractorAltaMaquinaria" method="post">
        <div class="form-check mb-3">
            <input asp-for="TieneCabina" class="form-check-input" />
            <label asp-for="TieneCabina" class="form-check-label">¿Tiene cabina?</label>
        </div>

        <div class="mb-3">
            <label asp-for="OtrasCaracteristicas" class="form-label">Otras características</label>
            <input asp-for="OtrasCaracteristicas" class="form-control" />
        </div>

        <button type="submit" class="btn btn-success">Siguiente ➡️</button>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }
    </form>
</div>
