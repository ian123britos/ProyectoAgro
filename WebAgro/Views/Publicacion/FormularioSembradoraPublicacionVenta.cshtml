
@using Dominio
@model Venta

@{
    ViewData["Title"] = "Paso 4 - Publicar venta";
}

<div class="container p-3 rounded shadow-sm" style="background-color: #fff; max-width: 600px;">
    <h5 class="mb-3">📢 Paso 4 - Publicar venta de la Sembradora</h5>

    <form asp-action="FormularioSembradoraAltaPublicacionVenta" method="post" enctype="multipart/form-data" class="small">

        <div class="mb-2">
            <label asp-for="Titulo" class="form-label">Título</label>
            <input asp-for="Titulo" class="form-control form-control-sm" />
        </div>

        <div class="mb-3">
            <label class="form-label">Imagen de la maquinaria</label>
            <input type="file" name="fotoArchivo" class="form-control form-control-sm" accept="image/*" />
        </div>

        <div class="mb-2">
            <label asp-for="PrecioVenta" class="form-label">Precio de Venta</label>
            <input asp-for="PrecioVenta" type="number" class="form-control form-control-sm" />
        </div>

        <button type="submit" class="btn btn-primary btn-sm w-100">📤 Publicar</button>

        @if (ViewBag.Exito != null)
        {
            <div class="alert alert-success mt-2 p-2 small">@ViewBag.Exito</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mt-2 p-2 small">@TempData["Error"]</div>
        }
    </form>
</div>