@using Dominio
@model Sembradora
<style>

    body {
        background-color: #e8f5e9; /* Verde suave */
    }

</style>
@{
    ViewData["Title"] = "Paso 3 - Información de la Sembradora";
}

<div class="container p-3 rounded shadow-sm" style="background-color: #fff; max-width: 600px;">
    <h5 class="mb-3">🌾 Paso 3 - Información de la Sembradora</h5>

    <form asp-action="FormularioSembradoraAltaMaquinaria" method="post" class="small">

        <div class="mb-3">
            <label asp-for="TipoDeSembradora" class="form-label">Tipo de Sembradora</label>
            <input asp-for="TipoDeSembradora" class="form-control form-control-sm" />
        </div>

        <div class="mb-3">
            <label asp-for="OtrasCaracteristicas" class="form-label">Otras características</label>
            <input asp-for="OtrasCaracteristicas" class="form-control form-control-sm" />
        </div>

        <button type="submit" class="btn btn-success btn-sm w-100">Siguiente ➡️</button>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mt-2 p-2 small">@TempData["Error"]</div>
        }
    </form>
</div>
