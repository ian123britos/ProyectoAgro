@using Dominio

<h1 class="mb-4 text-center fw-bold">Iniciar Sesión</h1>

<form asp-action="Login" method="post" class="mx-auto" style="max-width: 400px;">
    <div class="mb-3">
        <label for="email" class="form-label">Correo electrónico</label>
        <input id="email" name="Email" type="email" class="form-control" placeholder="usuario@ejemplo.com" required>
    </div>
    <div class="mb-3">
        <label for="contrasenia" class="form-label">Contraseña</label>
        <input id="contrasenia" name="Contrasenia" type="password" class="form-control" placeholder="********" required>
    </div>

    <button type="submit" class="btn btn-primary w-100">Ingresar</button>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mt-3 text-center">@TempData["Error"]</div>
    }
</form>

<div class="text-center mt-4">
    <a asp-action="FormularioRegistro" asp-controller="UsrCliente" class="btn btn-outline-secondary">
        ¿No tienes cuenta? Regístrate
    </a>
</div>
