@    using Dominio;
    using Dominio.EntidadesNegocio

<h1 class="mb-4 text-center fw-bold">Registro de Usuario</h1>

<form asp-action="RegistroUsuarioCliente" method="post" class="mx-auto" style="max-width: 400px;">
    <div class="mb-3">
        <label for="nombre" class="form-label">Nombre</label>
        <input id="nombre" name="Nombre" type="text" class="form-control" placeholder="Ingresa tu nombre completo" required>
    </div>
    <div class="mb-3">
        <label for="apellido" class="form-label">Apellido</label>
        <input id="apellido" name="Apellido" type="text" class="form-control" placeholder="Ingresa tu apellido" required>
    </div>
    <div class="mb-3">
        <label for="telefono" class="form-label">Teléfono</label>
        <input id="telefono" name="Telefono" type="tel" class="form-control" placeholder="Ej: 092345678" pattern="^\d{9}$" maxlength="9" required>
    </div>
    <div class="mb-3">
        <label for="email" class="form-label">Correo electrónico</label>
        <input id="email" name="Email" type="email" class="form-control" placeholder="usuario@ejemplo.com" required>
    </div>
    <div class="mb-3">
        <label for="contrasenia" class="form-label">Contraseña</label>
        <input id="contrasenia" name="Contrasenia" type="password" class="form-control" placeholder="********" required>
    </div>

    <input name="Rol" type="hidden" value="@Rol.CLI" />

    <button type="submit" class="btn btn-primary w-100">Registrarse</button>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mt-3 text-center">@TempData["Error"]</div>
    }
</form>

<div class="text-center mt-4">
    <a asp-action="index" asp-controller="home" class="btn btn-outline-secondary">Volver</a>
</div>
